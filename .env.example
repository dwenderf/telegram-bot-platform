# =============================================================
# Supabase / Database Connection (Platform Level)
# =============================================================

# Public Supabase credentials (required for client-side Auth & DB queries)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-publishable-key

# Brand & Redirect Configurations
NEXT_PUBLIC_APP_NAME="Agent Platform"
NEXT_PUBLIC_APP_URL=http://localhost:3000

# DATABASE_URL — CRITICAL SECURITY + CONNECTION NOTES
# 1) MUST connect as the restricted `bot_service` role, NEVER the `postgres`
#    superuser and NEVER a service-role connection. Superuser and service_role
#    connections BYPASS Row-Level Security, silently defeating all tenant
#    isolation (every tenant would see every other tenant's data).
# 2) MUST use the TRANSACTION-MODE POOLER, not the direct connection. The direct
#    host (db.PROJECT_REF.supabase.co:5432) is unreachable from serverless/Vercel
#    (fails with ENOTFOUND). Use the Supavisor pooler instead:
#      - host: aws-<n>-<region>.pooler.supabase.com   (from the Supabase dashboard)
#      - port: 6543  (transaction mode)
#      - username: bot_service.PROJECT_REF  (project ref appended to the role)
#    Get the pooler string from Supabase → Project Settings → Database →
#    Connection string → "Connection pooling" / Transaction; swap postgres →
#    bot_service and use the bot_service password.
# 3) Code requires `prepare: false` in the postgres client for the transaction pooler.
DATABASE_URL=postgresql://bot_service.your-project-ref:your-bot-service-password@aws-1-us-west-2.pooler.supabase.com:6543/postgres

# NOTE: SUPABASE_SERVICE_ROLE_KEY is intentionally NOT used by this application.
# The bot accesses the database exclusively as `bot_service` (subject to RLS) via
# DATABASE_URL. Do not add a service-role key here or use the Supabase JS client
# with service-role privileges in the data path — it would bypass RLS.

# =============================================================
# Anthropic API (Default Platform Model Provider)
# =============================================================
ANTHROPIC_API_KEY=your-anthropic-api-key

# =============================================================
# DeepSeek API (Alternative Platform Model Provider)
# =============================================================
# OPTIONAL — required only when MODEL_IDENTIFIER is a deepseek-* model.
# DEEPSEEK_API_KEY=your-deepseek-api-key

# =============================================================
# GitHub Webhook Signing Secret
# =============================================================
# OPTIONAL — only needed if the optional GitHub sync-source is enabled.
# Not used in the v1 direct-to-cache content path (content is pushed straight
# into doc_cache; there is no GitHub in v1). See PLANNING.md / DEPLOYMENT.md.
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret

# Model Configuration
# REQUIRED — no default; app fails to start if unset.
# MODEL_IDENTIFIER=claude-sonnet-5

# OPTIONAL — defaults to 2048
# MODEL_MAX_OUTPUT_TOKENS=2048

# OPTIONAL — defaults to 30
# CONTEXT_MESSAGE_HISTORY_LIMIT=30

# =============================================================
# Security & Cryptography
# =============================================================
# REQUIRED — shared application HMAC secret key (>= 32 bytes high-entropy random string)
# Used to derive tenant isolation scope IDs and obfuscate PII. App fails fast if unset.
# APP_HMAC_PEPPER=your-high-entropy-random-pepper-string-here

# =============================================================
# Privacy Policy Public URL
# =============================================================
# Public URL of the hosted privacy policy page (linked from the bot's in-chat notices).
# Must match the BotFather "Privacy Policy" field. Defaults to https://leguan.ai/privacy if unset.
# PRIVACY_POLICY_URL=https://leguan.ai/privacy